# =====================================================================
# Expense Manager — environment variables (TEMPLATE)
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit secrets.
# =====================================================================

# --- Firebase Admin (Firestore) ---
# Project ID is the only public value here; everything else below is a SECRET.
FIREBASE_PROJECT_ID=expanse-manager-2db40

# Local dev: absolute path to the service account JSON downloaded from
# Firebase Console → Project Settings → Service Accounts.
# Keep this file OUTSIDE the repo (e.g. ~/.secrets/...).
FIREBASE_ADMIN_SA_PATH=

# Production (Vercel): base64-encoded contents of the same JSON.
#   base64 < ~/.secrets/expanse-manager-sa.json | pbcopy
# Set this in Vercel env vars; LEAVE BLANK locally if FIREBASE_ADMIN_SA_PATH is set.
FIREBASE_ADMIN_SA_KEY=

# --- Auth ---
# JWT signing secret. Generate fresh:  openssl rand -base64 48
# MUST be at least 32 chars. Rotate on suspected compromise.
JWT_SECRET=

# --- Vercel Blob (receipts, Phase 2+) ---
# Get from Vercel project → Storage → Blob → "Connect to project".
BLOB_READ_WRITE_TOKEN=

# --- Vercel Cron (Phase 2+) ---
# Used to authenticate scheduled cron routes. Generate:  openssl rand -hex 32
CRON_SECRET=

# --- Gmail SMTP (Phase 2 emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Expense Manager <your-sender@example.com>"

# --- Gemini API (Phase 3 AI) ---
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Logging ---
LOG_LEVEL=debug
